{
  "enabled": true,
  "feature": "auto_typing",
  "method": "default",
  "options": {
    "apic": false,
    "axon": true,
    "basal": true,
    "rad": false,
    "soma": true,
    "zip_output": false
  },
  "rules": {
    "assign_missing": {
      "min_gain": -0.06,
      "min_score": 0.58
    },
    "branch_score_weights": {
      "apical": {
        "branch": 0.15,
        "path": 0.22,
        "prior": 0.15,
        "radius": 0.18,
        "z": 0.3
      },
      "axon": {
        "branch": 0.14,
        "path": 0.32,
        "prior": 0.1,
        "radial": 0.24,
        "radius": 0.2
      },
      "basal": {
        "branch": 0.22,
        "path": 0.15,
        "prior": 0.15,
        "radius": 0.18,
        "z": 0.3
      }
    },
    "class_labels": {
      "1": "soma",
      "2": "axon",
      "3": "basal",
      "4": "apical"
    },
    "ml_base_weight": 0.72,
    "ml_blend": 0.28,
    "notes": "This JSON controls the auto-labeling behavior (weights, thresholds, and options). Edit carefully; changes take effect when you save the file and re-run the batch or use the UI Save button.",
    "propagation_weights": {
      "branch_prior": 0.3,
      "children": 0.2,
      "iterations": 4,
      "parent": 0.35,
      "self": 0.35
    },
    "radius": {
      "copy_parent_if_zero": true
    },
    "seed_prior_threshold": 0.55,
    "smoothing": {
      "flip_margin": 0.1,
      "maj_fraction": 0.67
    }
  }
}